{
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts", "src/App-original.tsx", "src/components/navbar.tsx", "src/hooks/use-admin-status.tsx", "src/hooks/use-user-profile.tsx", "src/hooks/use-wishlist-count.tsx", "src/pages/admin-dashboard.tsx", "src/pages/coach-profile.tsx", "src/pages/coach-register.tsx", "src/pages/dashboard.tsx", "src/pages/onboarding.tsx"],
  "compilerOptions": {
    "noEmit": true,
    "jsx": "preserve",
    "lib": ["esnext", "dom", "dom.iterable"],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "references": [
    {
      "path": "../../lib/api-client-react"
    }
  ]
}
